rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PROYECTOS ──────────────────────────────────────────────────────────
    match /proyectos/{proyectoId} {
      // Leer: dueño o cualquier colaborador (compartidoCon)
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('compartidoCon', [])
      );
      // Crear: solo autenticados (crean su propio proyecto)
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      // Editar: dueño (gestión completa) o editor (solo ciertos campos)
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        (
          request.auth.uid in resource.data.get('compartidoCon', []) &&
          (resource.data.get('permisos', {})[request.auth.uid] == 'edicion' ||
           resource.data.get('permisos', {})[request.auth.uid] == 'ambos')
        )
      );
      // Borrar: solo el dueño
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // ── PUNTOS ────────────────────────────────────────────────────────────
    match /puntos/{puntoId} {
      // Leer: dueño del punto O colaborador del proyecto
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esColaboradorDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
      // Crear: autenticado y es editor del proyecto
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        esEditorDelProyecto(request.resource.data.proyectoId, request.auth.uid)
      );
      // Editar: dueño del punto o editor del proyecto
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esEditorDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
      // Borrar: dueño del punto o dueño del proyecto
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esDuenoDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
    }

    // ── CONEXIONES (FIBRAS) ───────────────────────────────────────────────
    match /conexiones/{conexionId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esColaboradorDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        esEditorDelProyecto(request.resource.data.proyectoId, request.auth.uid)
      );
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esEditorDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esDuenoDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
    }

    // ── BITÁCORA ──────────────────────────────────────────────────────────
    match /bitacora/{mensajeId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        esColaboradorDelProyecto(resource.data.proyectoId, request.auth.uid)
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.autorUid == request.auth.uid;
    }

    // ── CONFIGURACIONES ───────────────────────────────────────────────────
    match /configuraciones/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId;
    }

    // ── USUARIOS ──────────────────────────────────────────────────────────
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── EXPORTACIONES ─────────────────────────────────────────────────────
    match /exportaciones/{exportId} {
      allow read, write: if request.auth != null;
    }

    // ── FUNCIONES AUXILIARES ──────────────────────────────────────────────
    function esDuenoDelProyecto(proyectoId, uid) {
      return exists(/databases/$(database)/documents/proyectos/$(proyectoId)) &&
        get(/databases/$(database)/documents/proyectos/$(proyectoId)).data.ownerId == uid;
    }

    function esColaboradorDelProyecto(proyectoId, uid) {
      return exists(/databases/$(database)/documents/proyectos/$(proyectoId)) &&
        uid in get(/databases/$(database)/documents/proyectos/$(proyectoId)).data.get('compartidoCon', []);
    }

    function esEditorDelProyecto(proyectoId, uid) {
      let proyecto = get(/databases/$(database)/documents/proyectos/$(proyectoId)).data;
      let permiso = proyecto.get('permisos', {})[uid];
      return exists(/databases/$(database)/documents/proyectos/$(proyectoId)) &&
        uid in proyecto.get('compartidoCon', []) &&
        (permiso == 'edicion' || permiso == 'ambos');
    }
  }
}
